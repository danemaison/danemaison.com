---
import { skills } from '../data/skills';
---

<section id="skills">
  <h2>Skills</h2>
  <div class="groups">
    {
      skills.map((group) => (
        <div class="group">
          <span class="category">{group.category}</span>
          <div class="pills">
            {group.items.map((item) => (
              <span class="pill">{item}</span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  section {
    max-width: 560px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  h2 {
    font-size: 12px;
    font-weight: 600;
    text-align: center;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-family: var(--font-sans);
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .groups {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .category {
    font-family: var(--font-sans);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-dim);
    display: block;
    margin-bottom: 8px;
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .pill {
    background: var(--surface);
    color: var(--text-body);
    padding: 6px 14px;
    border-radius: 20px;
    font-family: var(--font-sans);
    font-size: 13px;
    border: 1px solid var(--border);
  }
</style>
