---
import { education } from '../data/education';
---

<section id="education">
  <h2>Education</h2>
  <div class="entries">
    {
      education.map((entry) => (
        <div class="entry">
          <div class="entry-info">
            <span class="school">{entry.school}</span>
            <span class="degree">{entry.degree}</span>
          </div>
          <span class="dates">{entry.dates}</span>
        </div>
      ))
    }
  </div>
</section>

<style>
  section {
    max-width: 640px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  h2 {
    font-size: 13px;
    font-weight: 600;
    text-align: center;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-family: var(--font-sans);
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .entries {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .entry {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }

  @media (max-width: 480px) {
    .entry {
      flex-direction: column;
      gap: 2px;
    }
  }

  .entry-info {
    display: flex;
    flex-direction: column;
  }

  .school {
    font-weight: 600;
    font-size: 17px;
    color: var(--text-primary);
  }

  .degree {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--text-dim);
  }

  .dates {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--text-dim);
    white-space: nowrap;
  }
</style>
